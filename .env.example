# Copy to .env and fill in the values you need. .env is gitignored.

ENVIRONMENT=dev
LOG_LEVEL=INFO

# Pick one. "none" disables embeddings & LLM but the rest of the pipeline
# still runs end-to-end so you can demo ingest + WebSocket fan-out.
LLM_PROVIDER=none           # one of: none, openai, bedrock

# OpenAI (cheapest for local dev)
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_COMPLETION_MODEL=gpt-4o-mini

# Bedrock (production target for public-sector use cases)
AWS_REGION=us-east-1
EMBEDDING_MODEL=amazon.titan-embed-text-v2:0
COMPLETION_MODEL=anthropic.claude-3-haiku-20240307-v1:0

# Storage (defaults work with docker-compose)
DATABASE_URL=postgresql+asyncpg://emberstream:emberstream@postgres:5432/emberstream
REDIS_URL=redis://redis:6379/0
